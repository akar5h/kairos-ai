# Kairos AI — example environment. Copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# ── LLM / semantic decision pass (optional) ────────────────────────────
# Only needed when you pass an LLMClient into KairosEngine.analyze (the
# semantic decision pass). Plain `kairos analyze` does not require it.
# OpenRouter API key — held as a SecretStr in analysis.llm_client.
OPENROUTER_API_KEY=
# Override the OpenRouter-compatible base URL (default: https://openrouter.ai/api/v1).
OPENROUTER_BASE_URL=
# Override the model the LLMClient uses (default: anthropic/claude-sonnet-4.5).
KAIROS_LLM_MODEL=

# ── Logging (optional) ─────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO).
KAIROS_LOG_LEVEL=
# Log renderer: json | console (default: json).
KAIROS_LOG_FORMAT=

# ── Detection thresholds (optional) ────────────────────────────────────
# Jaccard threshold for redundant-step detection (default: 0.60).
KAIROS_REDUNDANT_JACCARD_THRESHOLD=
# Minimum repeats before a loop is flagged (default: 3).
KAIROS_LOOP_MIN_REPEATS=

# ── Kairos Postgres (Day 10 — loop persistence) ─────────────────────────
# Dedicated kairos-pg container on host port 5434 (127.0.0.1 only).
# NOT shared with ledger-pg (:5432) or infra-cos-postgres (:5433).
#
# Full DSN — used by src/kairos/loop/db.py.  Fill in real values in .env.
KAIROS_PG_DSN=
# Individual parts used by deploy/docker-compose.yml to initialise the
# container on first start.  Supply the same credentials in KAIROS_PG_DSN.
KAIROS_PG_USER=
KAIROS_PG_PASSWORD=
KAIROS_PG_DB=kairos

# ── Nightly loop (Day 12) ───────────────────────────────────────────────
# Phoenix endpoint for the nightly fetch (default: http://localhost:6006).
KAIROS_PHOENIX_ENDPOINT=
# Phoenix project name to fetch from (default: default).
KAIROS_PHOENIX_PROJECT=
# Path to the Kairos context.yaml (default: <repo_root>/config/context.yaml).
KAIROS_CONTEXT_PATH=
# Directory for parquet fallback files and report output.
# (default: <repo_root>/output/loop_data)
KAIROS_LOOP_DATA_DIR=
# Kill switch — set to any non-empty value to disable the nightly loop.
# Loop exits cleanly with status=disabled when this is set.
# Document in ops runbook before enabling for production.
KAIROS_LOOP_DISABLED=
# Decision Ledger API URL for the EMIT stage (optional; omit to skip).
LEDGER_API_URL=
