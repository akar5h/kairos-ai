# Kairos AI — example environment. Copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# ── LLM / semantic decision pass (optional) ────────────────────────────
# Only needed when you pass an LLMClient into KairosEngine.analyze (the
# semantic decision pass). Plain `kairos analyze` does not require it.
# OpenRouter API key — held as a SecretStr in analysis.llm_client.
OPENROUTER_API_KEY=
# Override the OpenRouter-compatible base URL (default: https://openrouter.ai/api/v1).
OPENROUTER_BASE_URL=
# Override the model the LLMClient uses (default: anthropic/claude-sonnet-4.5).
KAIROS_LLM_MODEL=

# ── Logging (optional) ─────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO).
KAIROS_LOG_LEVEL=
# Log renderer: json | console (default: json).
KAIROS_LOG_FORMAT=

# ── Detection thresholds (optional) ────────────────────────────────────
# Jaccard threshold for redundant-step detection (default: 0.60).
KAIROS_REDUNDANT_JACCARD_THRESHOLD=
# Minimum repeats before a loop is flagged (default: 3).
KAIROS_LOOP_MIN_REPEATS=
