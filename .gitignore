# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
build/
dist/
.eggs/

# Virtual envs
.venv/
venv/
env/

# uv
.uv/
uv.lock

# Test / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Secrets / env
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials*.json

# Data / artifacts
data/
*.sqlite
*.db
/traces/
*.jsonl.gz

# Postgres volume data (kairos-pg Docker named volume mount — never commit)
pgdata/
kairos_pg_data/

# Eval corpus trace files (regenerable from ablation bundles via taubench_corpus.py)
# labels.jsonl and context.yaml are committed; raw trace JSONs are not.
eval/corpus/taubench/*.json

# Raw Phoenix span snapshots (regenerable via corpus.snapshot_phoenix_spans).
# The raw <trace_id>.json span files are large (~29M) and NOT committed; the
# committed manifest + resolved map + live_trace_ids.txt make the corpus
# composition and corpus_hash reproducible without them.
eval/corpus/live/*.json
!eval/corpus/live/snapshot_manifest.json
!eval/corpus/live/spotcheck_resolved.json

# Review queue and answers (regenerable / local reviewer data — never commit)
eval/review/queue.json
eval/review/answers.jsonl

# Editor / OS
.idea/
.vscode/
.DS_Store

# Review disagreement queue (local reviewer data — never commit)
eval/review/disagreement_queue.json

# Haywire-restart review queue (regenerable; never commit)
eval/review/haywire_queue.json

# Streamlit dashboard cache
eval/dashboard/.streamlit/

# Node modules
scripts/node_modules/
ui/node_modules/
ui/.next/

# Kairos analysis output views (generated output — never commit)
kairos-analysis-views/

# MLO generated output
.mlo/

# Nightly loop output (generated; never commit)
# Parquet fallback files written when Postgres is unavailable.
output/loop_data/
output/discovery_queue.json

# Eval harness worktrees (created under /tmp by harness.py — never in repo)
# Listed here as a safety net if someone runs eval from within the repo dir.
/tmp/kairos-eval-*/

# Eval runner scratch (temp scripts written by harness)
/tmp/kairos_eval_*.py
