# Live OTel emit wiring for a Paperclip `claude_local` agent (XER-69, Phase B).
#
# This is the telemetry env block a `claude_local` agent process must carry to
# emit. Claude Code (>=2.1.x) reads these at process start and emits OTel GenAI
# spans over OTLP — no agent code, zero `kairos` import on the hot path. Export
# is async (BatchSpanProcessor, background thread); a down backend retries-then-
# drops with zero added latency on the agent's critical path.
#
# DELIVERY: NOT via `adapterConfig.env` — that is inert for claude_local (the
# API stores env as binding objects; the adapter filters env to string values
# only and nothing resolves bindings on the spawn path, so it is dropped). The
# adapter must set these on the spawn `env` directly. See deploy/agent-telemetry.md
# for the exact insertion point + patch (XER-69 / XER-76).
#
# `<...>` placeholders: company_id / agent_id are static (agent fields); run_id /
# issue / project_id are per-run (run context) and interpolated in the adapter
# (OTel EnvDetector parses OTEL_RESOURCE_ATTRIBUTES literally, no `${VAR}`).

# ── enable Claude Code's native OTel tracer, traces only ───────────────────
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ── point at the always-on OTLP backend (deploy/docker-compose.yml) ────────
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── static provenance (resource attributes) — mirrors PaperclipNormalizer ──
# run_context keys company_id + agent_id; service.name carries agent identity.
OTEL_RESOURCE_ATTRIBUTES=service.name=paperclip-claude-<agent-key>,paperclip.company_id=<company-id>,paperclip.agent_id=<agent-id>
