# Live OTel emit wiring for a Paperclip `claude_local` agent (XER-69, Phase B).
#
# These keys go into the agent's `adapterConfig.env` (Paperclip server-side, one
# map per agent). Claude Code (>=2.1.x) reads them at process start and emits
# OTel GenAI spans over OTLP — no agent code, zero `kairos` import on the hot
# path. Export is async (BatchSpanProcessor, background thread); a down backend
# retries-then-drops with zero added latency on the agent's critical path.
#
# `<...>` placeholders are filled per agent. company_id / agent_id are STATIC
# (known at config time). run_id / issue / project_id are per-run DYNAMIC and
# CANNOT be set here: `adapterConfig.env` values are assigned literally (no
# interpolation) and Claude Code parses OTEL_RESOURCE_ATTRIBUTES via the
# standard OTel EnvDetector (no `${VAR}` expansion). Dynamic provenance is
# appended by the claude_local adapter at launch — see deploy/agent-telemetry.md.

# ── enable Claude Code's native OTel tracer, traces only ───────────────────
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ── point at the always-on OTLP backend (deploy/docker-compose.yml) ────────
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── static provenance (resource attributes) — mirrors PaperclipNormalizer ──
# run_context keys company_id + agent_id; service.name carries agent identity.
OTEL_RESOURCE_ATTRIBUTES=service.name=paperclip-claude-<agent-key>,paperclip.company_id=<company-id>,paperclip.agent_id=<agent-id>
